{
  "version": 2,
  "routes": [
    {
      "src": "/admin",
      "dest": "api/admin.js"
    },
    {
      "src": "/api/admin",
      "dest": "api/admin.js"
    },
    {
      "src": "/api/webhook",
      "dest": "api/webhook.js"
    },
    {
      "src": "/api/collage",
      "dest": "api/collage.js"
    }
  ],
  "functions": {
    "api/collage.js": {
      "maxDuration": 60
    },
    "api/webhook.js": {
      "maxDuration": 60
    }
  }
}
